{
  "name": "reachy_mini_desktop_app",
  "private": true,
  "version": "0.9.17",
  "type": "module",
  "engines": {
    "node": ">=24.4.0",
    "npm": ">=10.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "VITE_WEB_MODE=true vite build --outDir dist-web --base /v2/",
    "deploy:daemon-v2": "npm run build:web && rm -rf ../reachy_mini/src/reachy_mini/daemon/app/dashboard-v2/* && cp -r dist-web/* ../reachy_mini/src/reachy_mini/daemon/app/dashboard-v2/",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --no-watch",
    "tauri:dev:fresh": "yarn kill-daemon && yarn clean && yarn build:sidecar-macos && yarn tauri:dev",
    "tauri:build": "tauri build",
    "build:sidecar-macos": "bash ./scripts/build/build-sidecar-unix.sh",
    "build:sidecar-linux": "bash ./scripts/build/build-daemon-pyinstaller.sh",
    "build:sidecar-linux:legacy": "bash ./scripts/build/build-sidecar-unix.sh",
    "build:sidecar-windows": "powershell ./scripts/build/build-sidecar-windows.ps1",
    "build:sidecar-macos:develop": "REACHY_MINI_SOURCE=develop bash ./scripts/build/build-sidecar-unix.sh",
    "build:sidecar-linux:develop": "REACHY_MINI_SOURCE=develop bash ./scripts/build/build-daemon-pyinstaller.sh",
    "build:sidecar-windows:develop": "powershell -Command \"$env:REACHY_MINI_SOURCE='develop'; ./scripts/build/build-sidecar-windows.ps1\"",
    "build:sidecar-macos:main": "REACHY_MINI_SOURCE=main bash ./scripts/build/build-sidecar-unix.sh",
    "build:sidecar-linux:main": "REACHY_MINI_SOURCE=main bash ./scripts/build/build-daemon-pyinstaller.sh",
    "build:sidecar-windows:main": "powershell -Command \"$env:REACHY_MINI_SOURCE='main'; ./scripts/build/build-sidecar-windows.ps1\"",
    "build:sidecar:branch": "bash ./scripts/build/build-sidecar-with-branch.sh",
    "build:update:dev": "bash ./scripts/build/build-update.sh dev",
    "build:update:prod": "bash ./scripts/build/build-update.sh prod",
    "serve:updates": "bash ./scripts/utils/serve-updates.sh",
    "test:sidecar": "bash ./scripts/test/test-sidecar.sh",
    "test:app": "bash ./scripts/test/test-app.sh",
    "test:updater": "bash ./scripts/test/test-updater.sh",
    "test:update-prod": "bash ./scripts/test/test-update-prod.sh",
    "test:all": "yarn test:sidecar && yarn test:app && yarn test:updater",
    "kill-daemon": "./scripts/daemon/kill-daemon.sh",
    "check-daemon": "./scripts/daemon/check-daemon.sh",
    "kill-zombie-apps": "bash ./scripts/utils/kill-zombie-apps.sh",
    "reset-permissions": "bash ./scripts/utils/reset-macos-permissions.sh",
    "clean": "bash ./scripts/utils/clean.sh",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "vite": "^7.2.1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-virtual": "^3.13.12",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-http": "2.5.6",
    "@tauri-apps/plugin-positioner": "^2.3.1",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.24",
    "gsap": "^3.13.0",
    "leva": "^0.10.1",
    "postprocessing": "^6.37.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "swiper": "^12.0.3",
    "tauri-plugin-posthog-api": "^0.2.2",
    "three": "^0.181.0",
    "urdf-loader": "^0.12.6",
    "use-sound": "^5.0.0",
    "zustand": "^5.0.8"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
